# Exclui todo node_modules por padrão; o whitelist abaixo re-inclui as deps de
# produção (empacotamento com vsce --no-dependencies).
node_modules/**

# Dependencias de runtime existentes
!node_modules/@tootega/**
# tfx (file:../TFX) so precisa do dist; evita empacotar/escapar p/ os devDeps do TFX
node_modules/@tootega/tfx/node_modules/**
