// TokenGuard Database Schema - SYSx Module
// Database Markup Language (DBML)
// Tootega Pesquisa e Inovação - Todos os direitos reservados © 1999-2026
// https://dbdiagram.io/

Project TokenGuard {
  database_type: 'PostgreSQL'
  Note: 'TokenGuard SaaS - Sistema de Gerenciamento de Assinantes'
}


Table SYSxState{
  ID   byte         [pk, note: 'Primary key']
  Name nvarchar(20) [not null, note: 'State value']
  Note: 'Estate of a data record in a table row
    @seed
  |ID  |Name     |
  |1   |Active   |
  |2   |Inactive |
  |3   |Deleted  |
  |4   |Archived |
  '
}

Table SYSxUser {
  ID                   uniqueidentifier [pk, note: 'Primary key']
  UserName             nvarchar(256)    [not null, note: 'Username for login']
  NormalizedUserName   nvarchar(256)    [unique, not null, note: 'Normalized username for lookups']
  Email                nvarchar(256)    [not null, note: 'User email address']
  NormalizedEmail      nvarchar(256)    [not null, note: 'Normalized email for lookups']
  EmailConfirmed       bit              [not null, default: false, note: 'Email confirmation status']
  PasswordHash         nvarchar(500)    [not null, note: 'Hashed password']
  SecurityStamp        nvarchar(100)    [not null, note: 'Security stamp for invalidation']
  ConcurrencyStamp     nvarchar(100)    [not null, note: 'Concurrency control']
  PhoneNumber          nvarchar(20)     [not null, note: 'Phone number']
  PhoneNumberConfirmed bit              [not null, default: false, note: 'Phone confirmation status']
  TwoFactorEnabled     bit              [not null, default: false, note: 'Two-factor authentication enabled']
  LockoutEnd           datetimeoffset   [not null, note: 'Lockout end time']
  LockoutEnabled       bit              [not null, default: true, note: 'Lockout enabled']
  AccessFailedCount    int              [not null, default: 0, note: 'Failed access attempts']
  Name                 nvarchar(100)    [not null, note: 'User first name']
  CreatedAt            datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  LastLoginAt          datetime2        [not null, note: 'Last login timestamp']
  SYSxStateID          byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'System users table extending ASP.NET Identity'
}

Table SYSxUserProfile {
  ID                uniqueidentifier [pk, note: 'Primary key']
  SYSxUserID        uniqueidentifier [not null, ref: > SYSxUser.ID, delete: restrict, update: no action, note: 'FK to SYSxUser']
  SYSxStateID       byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']
  SYSxRoleProfileID uniqueidentifier [not null, ref: > SYSxRoleProfile.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleProfile']
  Note: 'Extended user profile information'
}

Table SYSxRoleProfile {
  ID          uniqueidentifier [pk, note: 'Primary key']
  SYSxStateID byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']
  Name        nvarchar(45)     [not null, note: 'User role name']
}

Table SYSxUserRoleClaim {
  ID              uniqueidentifier [pk, increment, note: 'Primary key']
  SYSxUserRoleID  uniqueidentifier [not null, ref: > SYSxRoleProfile.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleProfile']
  SYSxStateID     byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']
  SYSxRoleClaimID uniqueidentifier [not null, ref: > SYSxRoleClaims.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleClaims']
  Note: 'User role claims table for ASP.NET Identity'
}

Table SYSxRole {
  ID               uniqueidentifier [pk, note: 'Primary key']
  Name             nvarchar(256)    [not null, note: 'Role name']
  NormalizedName   nvarchar(256)    [unique, not null, note: 'Normalized role name']
  ConcurrencyStamp nvarchar(40)     [not null, note: 'Concurrency control']
  Description      nvarchar(500)    [not null, note: 'Human-readable description']
  IsSystem         bit              [not null, default: false, note: 'System role flag - cannot be deleted']
  Priority         int              [not null, default: 0, note: 'Priority for permission conflict resolution']
  CreatedAt        datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  UpdatedAt        datetime2        [not null, note: 'Last update timestamp']
  SYSxStateID      byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'System roles table extending ASP.NET Identity'
}


Table SYSxClaimGroup {
  ID          int          [pk, note: 'Primary key']
  Name        nvarchar(30) [not null, note: 'Group name']
  SYSxStateID byte         [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: '
  Claim       groups for organizing role claims
    
    @seed
  |           ID | Name     |
  |           1  | Global   |
  |           2  | Botão    |
  |           3  | Editor   |
  |           4  | Grupo    |
  |           5  | Aba      |
  '
}

Table SYSxRoleClaims {
  ID               uniqueidentifier [pk, increment, note: 'Primary key']
  SYSxRoleID       uniqueidentifier [not null, ref: > SYSxRole.ID, delete: restrict, update: no action, note: 'FK to SYSxRole']
  ClaimType        nvarchar(30)     [not null, note: 'Claim type identifier']
  ClaimValue       nvarchar(80)     [not null, note: 'Claim value']
  SYSxClaimGroupID int              [not null, ref: > SYSxClaimGroup.ID, delete: restrict, update: no action, note: 'FK to SYSxClaimGroup']
  SYSxStateID      byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Role claims table for ASP.NET Identity'
}

Table SYSxRefreshToken {
  ID              uniqueidentifier [pk, note: 'Primary key']
  SYSxUserID      uniqueidentifier [not null, ref: > SYSxUser.ID, delete: restrict, update: no action, note: 'FK to SYSxUser']
  Token           nvarchar(500)    [not null, note: 'Refresh token value']
  JwtID           nvarchar(100)    [not null, note: 'Associated JWT ID']
  CreatedAt       datetime2        [not null, note: 'Token creation timestamp']
  ExpiresAt       datetime2        [not null, note: 'Token expiration timestamp']
  RevokedAt       datetime2        [not null, note: 'Token revocation timestamp']
  ReplacedByToken nvarchar(500)    [not null, note: 'Replacement token value']
  RevokedReason   nvarchar(500)    [not null, note: 'Reason for revocation']
  CreatedByIP     nvarchar(50)     [not null, note: 'IP address that created the token']
  SYSxStateID     byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

 Note: 'Refresh tokens for JWT authentication'
}

                                                                                    
// ============================================================================
// APPLICATION MANAGEMENT
// ============================================================================

Table SYSxApplication {
  ID          uniqueidentifier [pk, note: 'Primary key']
  Name        nvarchar(100)    [unique, not null, note: 'Unique application identifier']
  Title       nvarchar(200)    [not null, note: 'Display title']
  Description nvarchar(500)    [not null, note: 'Application description']
  Icon        nvarchar(100)    [not null, note: 'Icon identifier or class']
  Route       nvarchar(200)    [not null, note: 'Frontend route path']
  ApiBaseURL  nvarchar(500)    [not null, note: 'API base URL']
  CanCreate   bit              [not null, default: true, note: 'Supports create operations']
  CanEdit     bit              [not null, default: true, note: 'Supports edit operations']
  CanDelete   bit              [not null, default: true, note: 'Supports delete operations']
  CanExport   bit              [not null, default: true, note: 'Supports export operations']
  CanPrint    bit              [not null, default: true, note: 'Supports print operations']
  CreatedAt   datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  UpdatedAt   datetime2        [not null, note: 'Last update timestamp']
  SYSxStateID byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'System applications/modules registry'
}

Table SYSxApplicationClaim {
  ID                uniqueidentifier [pk, note: 'Primary key']
  SYSxRoleClaimID   uniqueidentifier [not null, ref: > SYSxRoleClaims.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleClaims']
  SYSxApplicationID uniqueidentifier [not null, ref: > SYSxApplication.ID, delete: restrict, update: no action, note: 'FK to SYSxApplication']
  SYSxStateID       byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Junction table: permissions required by applications'
}

// ============================================================================
// MENU SYSTEM
// ============================================================================

Table SYSxMenuGroup {
  ID           uniqueidentifier [pk, note: 'Primary key']
  Name         nvarchar(100)    [unique, not null, note: 'Unique menu group identifier']
  Title        nvarchar(200)    [not null, note: 'Display title']
  Icon         nvarchar(100)    [not null, note: 'Icon identifier or class']
  DisplayOrder int              [not null, default: 0, note: 'Display order in navigation']
  CreatedAt    datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  UpdatedAt    datetime2        [not null, note: 'Last update timestamp']
  SYSxStateID  byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Menu groups for navigation organization'
}

Table SYSxMenuItem {
  ID                uniqueidentifier [pk, note: 'Primary key']
  SYSxApplicationID uniqueidentifier [not null, ref: > SYSxApplication.ID, delete: restrict, update: no action, note: 'FK to SYSxApplication']
  SYSxMenuGroupID   uniqueidentifier [not null, ref: > SYSxMenuGroup.ID, delete: restrict, update: no action, note: 'FK to SYSxMenuGroup']
  Name              nvarchar(100)    [not null, note: 'Menu item identifier']
  Title             nvarchar(200)    [not null, note: 'Display title']
  Icon              nvarchar(100)    [not null, note: 'Icon identifier or class']
  Route             nvarchar(200)    [not null, note: 'Frontend route path']
  DisplayOrder      int              [not null, default: 0, note: 'Display order within group']
  CreatedAt         datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  UpdatedAt         datetime2        [not null, note: 'Last update timestamp']
  SYSxStateID       byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Menu items linked to applications'
}

Table SYSxMenuItemMRU {
  ID             uniqueidentifier [pk, note: 'Primary key']
  SYSxUserID     uniqueidentifier [not null, ref: > SYSxUser.ID, delete: restrict, update: no action, note: 'FK to SYSxUser']
  SYSxMenuItemID uniqueidentifier [not null, ref: > SYSxMenuItem.ID, delete: restrict, update: no action, note: 'FK to SYSxMenuItem']
  AccessedAt     datetime2        [not null, note: 'Last access timestamp']
  AccessCount    int              [not null, default: 1, note: 'Total access count']
  Note: 'Most Recently Used menu items per user'
}

// ============================================================================
// PROFILE-APP RELATIONSHIP
// ============================================================================

Table SYSxProfileApp {
  ID                uniqueidentifier [pk, note: 'Primary key']
  SYSxRoleProfileID uniqueidentifier [not null, ref: > SYSxRoleProfile.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleProfile']
  SYSxApplicationID uniqueidentifier [not null, ref: > SYSxApplication.ID, delete: restrict, update: no action, note: 'FK to SYSxApplication']
  SYSxStateID       byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Junction table: profiles to applications'
}

Table SYSxProfileAppClaim {
  ID               uniqueidentifier [pk, note: 'Primary key']
  SYSxProfileAppID uniqueidentifier [not null, ref: > SYSxProfileApp.ID, delete: restrict, update: no action, note: 'FK to SYSxProfileApp']
  SYSxRoleClaimID  int              [not null, ref: > SYSxRoleClaims.ID, delete: restrict, update: no action, note: 'FK to SYSxRoleClaims']
  SYSxStateID      byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: 'Claims for a profile within an application'
}


// ============================================================================
// SUBSCRIPTION & PAYMENT
// ============================================================================

// Enum: BillingCycle  → Monthly = 1, Annual = 2
// Enum: PaymentMethod → Pix = 1, CreditCard = 2, BankSlip = 3
// Enum: SubscriptionStatus → PendingPayment = 1, Active = 2, PastDue = 3, Cancelled = 4, Expired = 5, Suspended = 6
// Enum: PaymentStatus → Pending = 1, Processing = 2, Approved = 3, Rejected = 4, Refunded = 5, Cancelled = 6, Expired = 7

Table SYSxSubscriptionPlan {
  ID                    smallint      [pk, increment, note: 'Primary key (auto-increment)']
  Code                  nvarchar(20)  [unique, not null, note: 'Unique plan code (e.g. PLAN_5, PLAN_20)']
  Name                  nvarchar(100) [not null, note: 'Plan display name']
  Description           nvarchar(500) [not null, default: '', note: 'Plan description']
  DocumentLimitPerMonth int           [not null, note: 'Max documents allowed per month']
  MonthlyPrice          decimal(10,2) [not null, note: 'Price per month (BRL)']
  AnnualPrice           decimal(10,2) [not null, note: 'Price per year (BRL) — includes 2-month discount']
  SortOrder             tinyint       [not null, default: 0, note: 'Display order in plan listing']
  CreatedAt             datetime2     [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  UpdatedAt             datetime2     [note: 'Last update timestamp']
  SYSxStateID           byte          [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']

  Note: '
  Available             subscription plans with pricing
    
    @seed
  |                     ID | Code     | Name        | DocumentLimitPerMonth | MonthlyPrice | AnnualPrice | SortOrder |
  |                     1  | PLAN_5   | Starter 5   | 5                     | 7.50         | 75.00       | 1         |
  |                     2  | PLAN_20  | Standard 20 | 20                    | 10.00        | 100.00      | 2         |
  |                     3  | PLAN_50  | Pro 50      | 50                    | 15.00        | 150.00      | 3         |
  |                     4  | PLAN_100 | Business 100| 100                   | 20.00        | 200.00      | 4         |
  '
}

Table SYSxSubscription {
  ID                     uniqueidentifier [pk, note: 'Primary key']
  SYSxUserID             uniqueidentifier [not null, ref: > SYSxUser.ID, delete: restrict, update: no action, note: 'FK to SYSxUser']
  SYSxCreditCardID       uniqueidentifier [null, ref: > SYSxCreditCard.ID, delete: set null, update: no action, note: 'FK to SYSxCreditCard (nullable for non-card payments)']

  SYSxSubscriptionPlanID smallint         [not null, ref: > SYSxSubscriptionPlan.ID, delete: restrict, update: no action, note: 'FK to SYSxSubscriptionPlan']
  BillingCycle           tinyint          [not null, note: 'BillingCycle enum: 1=Monthly, 2=Annual']
  Status                 tinyint          [not null, default: 1, note: 'SubscriptionStatus enum (default: PendingPayment)']
  PaymentMethod          tinyint          [not null, note: 'PaymentMethod enum: 1=Pix, 2=CreditCard, 3=BankSlip']
  PriceAtPurchase        decimal(10,2)    [not null, note: 'Locked-in price at subscription creation']
  CreatedAt              datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  ActivatedAt            datetime2        [note: 'When subscription became active (first payment confirmed)']
  CurrentPeriodStart     datetime2        [note: 'Current billing period start']
  CurrentPeriodEnd       datetime2        [note: 'Current billing period end']
  CancelledAt            datetime2        [note: 'Cancellation timestamp']
  UpdatedAt              datetime2        [note: 'Last update timestamp']
  FailedPaymentAttempts  tinyint          [not null, default: 0, note: 'Failed payment attempts for automatic suspension']

  Note: 'User subscriptions linking users to plans with billing lifecycle tracking'
}

Table SYSxCreditCard {
  ID                 uniqueidentifier [pk, note: 'Primary key']
  SYSxSubscriptionID uniqueidentifier [not null, ref: > SYSxSubscription.ID, delete: restrict, update: no action, note: 'FK to SYSxSubscription']
  SYSxUserID         uniqueidentifier [not null, ref: > SYSxUser.ID, delete: restrict, update: no action, note: 'FK to SYSxUser']
  SYSxStateID        byte             [not null, ref: > SYSxState.ID, delete: restrict, update: no action, note: 'FK to SYSxState']
  Data               varbinary(max)   [not null, note: 'Encrypted credit card data (PCI compliant encryption)']
  CardholderName     nvarchar(100)    [not null, note: 'Name on the card']
  Last4Digits        char(4)          [not null, note: 'Last 4 digits of the card number']
  ExpirationMonth    tinyint          [not null, note: 'Card expiration month (1-12)']
  ExpirationYear     smallint         [not null, note: 'Card expiration year (e.g. 2025)']
  IsDefault          bit              [not null, default: false, note: 'Indicates if this is the default payment method']
  CreatedAt          datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  Note: 'Stored credit card information for users (only non-sensitive data)'
}

Table SYSxPayment {
  ID                 uniqueidentifier [pk, note: 'Primary key']
  SYSxSubscriptionID uniqueidentifier [not null, ref: > SYSxSubscription.ID, delete: restrict, update: no action, note: 'FK to SYSxSubscription']
  SYSxCreditCardID   uniqueidentifier [null, ref: > SYSxCreditCard.ID, delete: set null, update: no action, note: 'FK to SYSxCreditCard (nullable for non-card payments)']
  PaymentMethod      tinyint          [not null, note: 'PaymentMethod enum: 1=Pix, 2=CreditCard, 3=BankSlip']
  Status             tinyint          [not null, default: 1, note: 'PaymentStatus enum (default: Pending)']
  Amount             decimal(10,2)    [not null, note: 'Payment amount (BRL)']
  SupplierFees       decimal(10,2)    [not null, default: 0, note: 'Fees charged by payment supplier']
  SupplierPaymentID  nvarchar(100)    [note: 'External payment ID from supplier (MercadoPago, etc.)']
  SupplierStatus     nvarchar(50)     [note: 'Raw status string from supplier']
  StatusDetail       nvarchar(500)    [note: 'Detailed status/error message']
  PaymentData        nvarchar(max)    [note: 'Pix: QR code string; BankSlip: barcode/URL']
  PaymentDataImage   nvarchar(max)    [note: 'Pix: QR code base64 image; BankSlip: PDF URL']
  CreatedAt          datetime2        [not null, default: `GETUTCDATE()`, note: 'Record creation timestamp']
  PaidAt             datetime2        [note: 'Payment confirmation timestamp']
  ExpiresAt          datetime2        [note: 'Payment expiration (Pix/BankSlip timeout)']
  UpdatedAt          datetime2        [note: 'Last update timestamp']
  IdempotencyKey     nvarchar(100)    [unique, note: 'Idempotency key to prevent duplicate payments']
  CreatedByIP        nvarchar(50)     [not null, note: 'IP address that initiated the payment']

  Note: 'Individual payment transactions tied to subscriptions'
}
